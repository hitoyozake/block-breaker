{
  "name": "Block Breaker",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:4-24-trixie",
  "postCreateCommand": "npm install && npx playwright install --with-deps chromium",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Game Dev Server",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-playwright.playwright"
      ]
    }
  }
}
